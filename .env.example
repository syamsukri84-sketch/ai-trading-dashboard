AI_TRADING_DASHBOARD_PASSWORD=ganti_password_ini
AI_TRADING_PRICE_UPDATE_ONLINE=true
AI_TRADING_EXTERNAL_SERVICES=false
AI_TRADING_DUPLICATE_POLICY=skip
AI_TRADING_PREDICTION_RUN_TYPE=FINAL
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE=ai_trading
# Gemini API resmi (BUKAN gemini.google.com chat UI) -- buat key di
# https://aistudio.google.com/apikey. Dipakai untuk fitur "Cari Kata Kunci
# Sentimen Otomatis" di tab Sentimen Pasar. Set AI_TRADING_EXTERNAL_SERVICES=true
# juga supaya fitur online (termasuk ini) aktif.
GEMINI_API_KEY=ganti_dengan_api_key_anda
GEMINI_MODEL=gemini-flash-latest
